# База данных
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_cloud
DB_USER=crm
DB_PASSWORD=crm

# Порт backend (локально)
SERVER_PORT=18080

# VK API — токен сообщества и его числовой ID (без минуса)
VK_COMMUNITY_TOKEN=
VK_COMMUNITY_ID=0

# VK Callback API — заполнить после настройки в разделе API → Callback API сообщества
# VK_CALLBACK_SECRET — секретный ключ из настроек Callback API
# VK_CONFIRMATION_TOKEN — строка подтверждения (вкладка "Настройки сервера")
VK_CALLBACK_SECRET=
VK_CONFIRMATION_TOKEN=
